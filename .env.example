# Copy this file to `.env` and fill in real values.
# All four variables are REQUIRED. The server refuses to start if any are missing.

# PostgreSQL connection string (lib/pq format).
# Example: postgres://chirpy:chirpy@localhost:5432/chirpy?sslmode=disable
DB_URL=postgres://USER:PASSWORD@localhost:5432/chirpy?sslmode=disable

# Runtime platform. Set to "dev" to enable the destructive POST /admin/reset endpoint.
# Use anything else (e.g. "prod") in production.
PLATFORM=dev

# Secret used to sign HS256 JWT access tokens.
# Use a long, high-entropy random value in production. Do NOT commit the real value.
# Generate one with: openssl rand -hex 64
SECRET=replace-me-with-a-long-random-string

# Shared API key expected from the Polka payment webhook (Authorization: ApiKey <POLKA_KEY>).
POLKA_KEY=replace-me-with-the-polka-api-key
